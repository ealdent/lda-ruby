#!/usr/bin/env bash
set -euo pipefail

build_gem() {
  bundle exec rake build >/dev/null
  ls -1t pkg/lda-ruby-*.gem | head -n1
}

verify_rust_unavailable_when_forced() {
  local gem_home="$1"

  env \
    "GEM_HOME=${gem_home}" \
    "GEM_PATH=${gem_home}" \
    "LDA_RUBY_BACKEND=rust" \
    ruby -e '
      require "lda-ruby"
      corpus = Lda::Corpus.new
      corpus.add_document(Lda::TextDocument.new(corpus, "alpha beta"))

      begin
        Lda::Lda.new(corpus)
      rescue LoadError
        puts("SMOKE mode=rust unavailable as expected")
        exit 0
      end

      abort("Expected rust backend request to fail when Rust extension is unavailable")
    '
}

run_smoke_modes() {
  local gem_home="$1"
  local expected_auto_backend="$2"
  local expect_rust="$3"

  GEM_HOME="${gem_home}" \
    GEM_PATH="${gem_home}" \
    EXPECTED_GEM_HOME_PREFIX="${gem_home}" \
    EXPECTED_BACKEND="${expected_auto_backend}" \
    SMOKE_MODE="auto" \
    ruby ./bin/packaged-gem-smoke.rb

  GEM_HOME="${gem_home}" \
    GEM_PATH="${gem_home}" \
    EXPECTED_GEM_HOME_PREFIX="${gem_home}" \
    EXPECTED_BACKEND="pure_ruby" \
    SMOKE_MODE="pure" \
    LDA_RUBY_BACKEND="pure" \
    ruby ./bin/packaged-gem-smoke.rb

  GEM_HOME="${gem_home}" \
    GEM_PATH="${gem_home}" \
    EXPECTED_GEM_HOME_PREFIX="${gem_home}" \
    EXPECTED_BACKEND="native" \
    SMOKE_MODE="native" \
    LDA_RUBY_BACKEND="native" \
    ruby ./bin/packaged-gem-smoke.rb

  if [[ "${expect_rust}" == "true" ]]; then
    GEM_HOME="${gem_home}" \
      GEM_PATH="${gem_home}" \
      EXPECTED_GEM_HOME_PREFIX="${gem_home}" \
      EXPECTED_BACKEND="rust" \
      SMOKE_MODE="rust" \
      LDA_RUBY_BACKEND="rust" \
      ruby ./bin/packaged-gem-smoke.rb
  else
    verify_rust_unavailable_when_forced "${gem_home}"
  fi
}

run_case() {
  local label="$1"
  local gem_file="$2"
  local gem_home="$3"
  local policy="$4"
  local expected_rust="$5"
  local expected_auto_backend="$6"

  echo "==> ${label}"
  rm -rf "${gem_home}"
  mkdir -p "${gem_home}"

  local -a install_env=(
    "GEM_HOME=${gem_home}"
    "GEM_PATH=${gem_home}"
  )
  if [[ "${policy}" != "__unset__" ]]; then
    install_env+=("LDA_RUBY_RUST_BUILD=${policy}")
  fi

  env "${install_env[@]}" gem install --local "${gem_file}" --no-document >/tmp/lda-ruby-gem-install-rust.log 2>&1

  local runtime_flags
  runtime_flags=$(env \
    "GEM_HOME=${gem_home}" \
    "GEM_PATH=${gem_home}" \
    ruby -e 'require "lda-ruby"; puts "RUST=#{Lda::RUST_EXTENSION_LOADED} NATIVE=#{Lda::NATIVE_EXTENSION_LOADED}"')
  echo "${runtime_flags}"
  echo "${runtime_flags}" | grep -q "RUST=${expected_rust}"
  echo "${runtime_flags}" | grep -q "NATIVE=true"

  run_smoke_modes "${gem_home}" "${expected_auto_backend}" "${expected_rust}"
}

main() {
  if ! command -v cargo >/dev/null 2>&1; then
    echo "cargo is required for ./bin/test-packaged-gem-rust-enabled" >&2
    exit 1
  fi

  local gem_file
  gem_file="$(build_gem)"

  local temp_root
  temp_root="$(mktemp -d)"
  trap "rm -rf '${temp_root}'" EXIT

  run_case "auto policy (cargo available) enables Rust backend" "${gem_file}" "${temp_root}/auto" "__unset__" "true" "rust"
  run_case "never policy disables Rust backend even with cargo" "${gem_file}" "${temp_root}/never" "never" "false" "native"
  run_case "always policy (cargo available) enables Rust backend" "${gem_file}" "${temp_root}/always" "always" "true" "rust"

  echo "Packaged gem Rust-enabled checks passed."
}

main "$@"
